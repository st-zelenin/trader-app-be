HOST=0.0.0.0
PORT=7070
NODE_ENV=development
LOG_LEVEL=info

AzureKeyVaultEndpoint=https://your-vault.vault.azure.net/
CosmosDbEndpoint=https://your-cosmos.documents.azure.com:443/

# --- Local dev (optional): avoid Key Vault ---
# Option A: refresh Azure CLI, then use Key Vault (same as .NET Functions)
#   az login --scope https://vault.azure.net/.default
#
# Option B: put secrets in .env (GetUser only needs CosmosDbKey)
# CosmosDbKey=your-cosmos-primary-key
# UseLocalSecrets=true
# SECRET_BINANCE={"apiKey":"...","secretKey":"..."}
# SECRET_BYBIT_SPOT={"apiKey":"...","secretKey":"..."}
# SECRET_CRYPTO_SPOT_TRADE={"apiKey":"...","secretKey":"..."}
# SECRET_GATE_SPOT_WRITE={"apiKey":"...","secretKey":"..."}

# Comma-separated origins (GUI dev server + optional LAN UI)
CORS_ORIGINS=http://localhost:4201,http://localhost:4200
